{
  "name": "timeoff-microservice",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:timeoff": "nest build timeoff-service",
    "build:mock-hcm": "nest build mock-hcm",
    "build": "npm run build:timeoff && npm run build:mock-hcm",
    "start": "nest start timeoff-service",
    "start:dev": "nest start timeoff-service --watch",
    "start:mock-hcm": "nest start mock-hcm",
    "start:mock-hcm:dev": "nest start mock-hcm --watch",
    "test": "jest --config apps/timeoff-service/jest.config.ts --passWithNoTests",
    "test:watch": "jest --config apps/timeoff-service/jest.config.ts --watch",
    "test:cov": "jest --config apps/timeoff-service/jest.config.ts --coverage",
    "test:e2e": "jest --config apps/timeoff-service/jest.e2e.config.ts --forceExit --runInBand",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d apps/timeoff-service/src/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d apps/timeoff-service/src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/config": "^3.0.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
